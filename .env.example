# Esempio di .env per il run locale del Google Ads pipeline.
# Copia in .env e riempi VERTICA_USER e VERTICA_PASSWORD con i tuoi valori.
# .env e' nel .gitignore, non viene committato.

# --- Vertica (TEST mode -> scrive su tabelle *_TEST) ---
VERTICA_HOST=vertica11.esprinet.com
VERTICA_PORT=5433
VERTICA_DATABASE=Esprinet
VERTICA_USER=
VERTICA_PASSWORD=

# --- Google Ads multi-tenant (Esprinet + Zeliatech) ---
STORAGE_TYPE=vertica
TEST_MODE=true
GOOGLE_API_VERSION=v23
GOOGLE_ADS_CONFIG_FILES=social/platforms/google/google-ads-9474097201.yml,social/platforms/google/google-ads-7604543417.yml
